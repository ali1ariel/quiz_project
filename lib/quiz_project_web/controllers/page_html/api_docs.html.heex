<Layouts.app flash={@flash} current_user={assigns[:current_user]} wide>
  <div id="api-docs" class="space-y-10">
    <section class="relative overflow-hidden rounded-3xl border border-base-300 bg-base-200 px-6 py-10 sm:px-10">
      <div class="absolute -right-20 -top-20 size-64 rounded-full bg-primary/10 blur-3xl"></div>
      <div class="relative max-w-3xl space-y-4">
        <div class="flex flex-wrap items-center gap-3">
          <span class="rounded-full bg-primary px-3 py-1 text-xs font-semibold text-primary-content">
            API v1
          </span>
          <span class="text-sm opacity-60">JSON · Bearer Token · UTF-8</span>
        </div>
        <h1 class="text-3xl font-bold tracking-tight sm:text-5xl">API de quizzes</h1>
        <p class="max-w-2xl text-base leading-7 opacity-70 sm:text-lg">
          Crie, leia e altere rascunhos, gerencie questões e publique versões usando o mesmo
          domínio seguro da aplicação web.
        </p>
        <div class="flex flex-wrap gap-3 pt-2 text-sm">
          <a
            href="#autenticacao"
            class="rounded-full bg-primary px-5 py-2.5 font-semibold text-primary-content transition hover:-translate-y-0.5"
          >
            Começar pela autenticação
          </a>
          <a
            href="#usar-com-ia"
            class="rounded-full border border-base-300 px-5 py-2.5 font-semibold transition hover:border-primary hover:text-primary"
          >
            Usar com IA
          </a>
          <a
            href="#endpoints"
            class="rounded-full border border-base-300 px-5 py-2.5 font-semibold transition hover:border-primary hover:text-primary"
          >
            Ver endpoints
          </a>
        </div>
      </div>
    </section>

    <section id="visao-geral" class="grid gap-4 md:grid-cols-3">
      <div class="rounded-2xl border border-base-300 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary">Base URL</p>
        <code class="mt-3 block break-all text-sm">/api/v1</code>
      </div>
      <div class="rounded-2xl border border-base-300 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary">Content-Type</p>
        <code class="mt-3 block break-all text-sm">application/json</code>
      </div>
      <div class="rounded-2xl border border-base-300 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary">Autorização</p>
        <code class="mt-3 block break-all text-sm">Bearer quiz_...</code>
      </div>
    </section>

    <section id="autenticacao" class="scroll-mt-6 space-y-5">
      <div>
        <p class="text-sm font-semibold text-primary">01 · Autenticação</p>
        <h2 class="mt-1 text-2xl font-bold">Gere um token de acesso</h2>
        <p class="mt-2 max-w-3xl leading-7 opacity-70">
          A forma recomendada é gerar o token pela sua conta. Ele é exibido uma única vez:
          copie-o, guarde-o como segredo e envie-o no header Authorization das chamadas seguintes.
        </p>
      </div>
      <div
        id="token-via-settings"
        class="flex flex-col gap-4 rounded-2xl border border-primary/30 bg-primary/5 p-5 sm:flex-row sm:items-center sm:justify-between"
      >
        <div>
          <h3 class="font-bold">Pela interface da conta — recomendado</h3>
          <p class="mt-1 text-sm leading-6 opacity-70">
            Entre na sua conta, abra Configurações, selecione Tokens e crie uma credencial para
            sua integração ou agente de IA.
          </p>
        </div>
        <.link
          id="api-docs-open-token-settings"
          href={~p"/configuracoes?tab=tokens"}
          class="inline-flex shrink-0 items-center justify-center gap-2 rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-primary-content transition hover:-translate-y-0.5"
        >
          Abrir configurações <.icon name="hero-arrow-right" class="size-4" />
        </.link>
      </div>
      <div>
        <h3 class="font-bold">Alternativa programática</h3>
        <p class="mt-1 text-sm leading-6 opacity-70">
          Em um cliente sob seu controle, também é possível emitir o token diretamente pela API.
        </p>
      </div>
      <div class="overflow-hidden rounded-2xl border border-base-300 bg-neutral text-neutral-content">
        <div class="flex items-center justify-between border-b border-white/10 px-5 py-3 text-xs opacity-70">
          <span>Emitir token</span><span>POST /api/v1/auth/tokens</span>
        </div>
        <pre class="overflow-x-auto p-5 text-sm leading-6"><code phx-no-curly-interpolation>curl -X POST <%= url(~p"/api/v1/auth/tokens") %> \
  -H 'Content-Type: application/json' \
  -d '{
    "email": "voce@exemplo.com",
    "password": "sua-senha",
    "name": "Meu agente"
  }'</code></pre>
      </div>
      <div class="overflow-hidden rounded-2xl border border-base-300 bg-neutral text-neutral-content">
        <div class="border-b border-white/10 px-5 py-3 text-xs opacity-70">
          Resposta · 201 Created
        </div>
        <pre class="overflow-x-auto p-5 text-sm leading-6"><code phx-no-curly-interpolation>{
  "data": {
    "id": "UUID_DO_TOKEN",
    "name": "Meu agente",
    "token": "quiz_SEGREDO_EXIBIDO_UMA_VEZ",
    "token_type": "Bearer",
    "scopes": ["quizzes:read", "quizzes:write", "quizzes:publish"],
    "expires_at": null
  }
}</code></pre>
      </div>
      <div class="overflow-hidden rounded-2xl border border-base-300 bg-neutral text-neutral-content">
        <div class="border-b border-white/10 px-5 py-3 text-xs opacity-70">Usar o token</div>
        <pre class="overflow-x-auto p-5 text-sm leading-6"><code phx-no-curly-interpolation>curl <%= url(~p"/api/v1/quizzes") %> \
  -H 'Authorization: Bearer quiz_SEU_TOKEN'</code></pre>
      </div>
      <.api_fields title="Escopos emitidos por padrão">
        <:field name="quizzes:read" type="scope" presence="Leitura">
          Consulta quizzes, versões e valida rascunhos.
        </:field>
        <:field name="quizzes:write" type="scope" presence="Escrita">
          Cria, importa e altera quizzes, rascunhos, questões e alternativas.
        </:field>
        <:field name="quizzes:publish" type="scope" presence="Publicação">
          Publica uma versão validada. Todos os tokens criados atualmente recebem os três escopos.
        </:field>
      </.api_fields>
      <p class="rounded-2xl border border-warning/40 bg-warning/10 p-4 text-sm leading-6">
        Revogue tokens pela tela de Configurações ou envie <code>DELETE /api/v1/auth/token</code>
        com o mesmo header Authorization.
      </p>
    </section>

    <section
      id="usar-com-ia"
      class="scroll-mt-6 space-y-6 overflow-hidden rounded-3xl border border-primary/25 bg-primary/5 p-6 sm:p-8"
    >
      <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-primary">Usar com IA</p>
          <h2 class="mt-1 text-2xl font-bold">Conecte um assistente de IA</h2>
          <p class="mt-3 leading-7 opacity-75">
            Ao pedir que uma IA crie ou importe quizzes, envie o link desta página e peça que
            ela consulte os endpoints, a autenticação e o contrato JSON antes de agir.
            Compartilhe o token somente em uma ferramenta confiável e nunca em conversas públicas.
          </p>
        </div>
        <div class="shrink-0 rounded-2xl bg-base-100 p-4 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] opacity-55">
            Link para compartilhar
          </p>
          <code id="api-docs-public-url" class="mt-2 block break-all text-sm text-primary">
            {url(~p"/api/docs")}
          </code>
        </div>
      </div>
      <div id="api-ai-prompt" class="rounded-2xl border border-base-300 bg-base-100 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] opacity-55">
          Prompt sugerido
        </p>
        <p class="mt-2 text-sm leading-6">
          Consulte <code>{url(~p"/api/docs")}</code> antes de continuar. Siga a API v1 e use o
          endpoint de importação descrito na documentação.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <div class="rounded-2xl border border-base-300 bg-base-100 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-primary">
            API REST direta
          </p>
          <p class="mt-2 text-sm leading-6 opacity-75">
            Funciona quando o assistente consegue fazer requisições HTTP para este domínio. As
            versões web dos serviços de IA, porém, navegam por proxies com restrições próprias:
            a chamada pode falhar com erros como <code>Failed to fetch</code>, sem nem retornar
            um status HTTP.
          </p>
        </div>
        <div class="rounded-2xl border border-base-300 bg-base-100 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-primary">
            Servidor MCP
          </p>
          <p class="mt-2 text-sm leading-6 opacity-75">
            O Model Context Protocol contorna essas restrições: o cliente de IA conecta o
            servidor como ferramenta nativa e chama a aplicação por conta própria, com o mesmo
            Bearer token e as mesmas regras de escopo e propriedade da API REST.
          </p>
        </div>
      </div>

      <.api_endpoint
        id="endpoint-mcp"
        method="POST"
        path="/api/mcp"
        scope="Bearer token"
        response="JSON-RPC 2.0"
      >
        <p class="text-sm leading-6 opacity-75">
          Servidor MCP stateless sobre o transporte Streamable HTTP. Aceita as mensagens <code>initialize</code>, <code>ping</code>,
          <code>tools/list</code>
          e <code>tools/call</code>; notificações respondem <code>202</code>. GET e DELETE
          retornam <code>405</code>
          — não há sessões nem streams SSE. Erros de domínio chegam
          como resultado da ferramenta com <code>isError: true</code>
          e o mesmo objeto <code>error</code>
          da API REST em <code>structuredContent</code>.
        </p>
        <.api_fields
          title="Ferramentas disponíveis"
          name_label="Ferramenta"
          type_label="Equivalente REST"
          presence_label="Escopo"
        >
          <:field name="list_quizzes" type="GET /quizzes" presence="token válido">
            Lista os quizzes da conta com resumo das versões.
          </:field>
          <:field name="get_quiz" type="GET /quizzes/:id" presence="token válido">
            Busca um quiz pelo ID.
          </:field>
          <:field name="create_quiz" type="POST /quizzes" presence="quizzes:write">
            Cria um quiz em rascunho.
          </:field>
          <:field name="import_quiz" type="POST /quizzes/import" presence="quizzes:write">
            Importa um quiz completo; o argumento <code>data</code> usa o formato de importação.
          </:field>
          <:field name="set_quiz_active" type="PATCH /quizzes/:id" presence="quizzes:write">
            Ativa ou desativa um quiz.
          </:field>
          <:field
            name="create_quiz_draft"
            type="POST /quizzes/:id/drafts"
            presence="quizzes:write"
          >
            Garante um rascunho editável.
          </:field>
          <:field name="get_quiz_version" type="GET /quiz-versions/:id" presence="token válido">
            Busca uma versão completa, com questões e alternativas.
          </:field>
          <:field
            name="update_quiz_version"
            type="PATCH /quiz-versions/:id"
            presence="quizzes:write"
          >
            Atualiza metadados de um rascunho.
          </:field>
          <:field
            name="validate_quiz_version"
            type="POST /quiz-versions/:id/validate"
            presence="token válido"
          >
            Valida um rascunho sem alterar nada.
          </:field>
          <:field
            name="publish_quiz_version"
            type="POST /quiz-versions/:id/publish"
            presence="quizzes:publish"
          >
            Publica um rascunho validado.
          </:field>
          <:field
            name="create_question"
            type="POST /quiz-versions/:id/questions"
            presence="quizzes:write"
          >
            Cria uma questão no rascunho.
          </:field>
          <:field name="update_question" type="PATCH /questions/:id" presence="quizzes:write">
            Atualiza uma questão; <code>options</code> omitido preserva as alternativas.
          </:field>
          <:field name="delete_question" type="DELETE /questions/:id" presence="quizzes:write">
            Remove uma questão do rascunho.
          </:field>
        </.api_fields>
        <div class="overflow-hidden rounded-xl bg-neutral text-neutral-content">
          <div class="border-b border-white/10 px-5 py-3 text-xs opacity-70">
            Exemplo · chamada de ferramenta
          </div>
          <pre class="overflow-x-auto p-5 text-sm leading-6"><code phx-no-curly-interpolation>curl -X POST <%= url(~p"/api/mcp") %> \
  -H 'Authorization: Bearer quiz_SEU_TOKEN' \
  -H 'Content-Type: application/json' \
  -d '{
    "jsonrpc": "2.0",
    "id": 1,
    "method": "tools/call",
    "params": {"name": "list_quizzes", "arguments": {}}
  }'</code></pre>
        </div>
      </.api_endpoint>

      <div class="group/ai space-y-4">
        <input type="radio" name="ai-tabs" id="ai-tab-claude" class="hidden" checked />
        <input type="radio" name="ai-tabs" id="ai-tab-chatgpt" class="hidden" />
        <input type="radio" name="ai-tabs" id="ai-tab-gemini" class="hidden" />

        <div>
          <h3 class="text-xl font-bold">Como conectar em cada assistente</h3>
          <div class="mt-3 flex flex-wrap gap-2" role="tablist">
            <label
              for="ai-tab-claude"
              class="cursor-pointer rounded-full border border-base-300 bg-base-100 px-4 py-2 text-sm font-semibold transition hover:border-primary hover:text-primary group-has-[#ai-tab-claude:checked]/ai:border-primary group-has-[#ai-tab-claude:checked]/ai:bg-primary group-has-[#ai-tab-claude:checked]/ai:text-primary-content"
            >
              Claude
            </label>
            <label
              for="ai-tab-chatgpt"
              class="cursor-pointer rounded-full border border-base-300 bg-base-100 px-4 py-2 text-sm font-semibold transition hover:border-primary hover:text-primary group-has-[#ai-tab-chatgpt:checked]/ai:border-primary group-has-[#ai-tab-chatgpt:checked]/ai:bg-primary group-has-[#ai-tab-chatgpt:checked]/ai:text-primary-content"
            >
              ChatGPT
            </label>
            <label
              for="ai-tab-gemini"
              class="cursor-pointer rounded-full border border-base-300 bg-base-100 px-4 py-2 text-sm font-semibold transition hover:border-primary hover:text-primary group-has-[#ai-tab-gemini:checked]/ai:border-primary group-has-[#ai-tab-gemini:checked]/ai:bg-primary group-has-[#ai-tab-gemini:checked]/ai:text-primary-content"
            >
              Gemini
            </label>
          </div>
        </div>

        <div
          id="ai-panel-claude"
          class="hidden space-y-4 group-has-[#ai-tab-claude:checked]/ai:block"
        >
          <div class="rounded-2xl border border-base-300 bg-base-100 p-5">
            <h4 class="font-bold">Na interface web (claude.ai)</h4>
            <p class="mt-1 text-sm leading-6 opacity-75">
              O caminho mais simples é liberar este domínio para chamadas diretas:
            </p>
            <ol class="mt-3 list-decimal space-y-2 pl-5 text-sm leading-6">
              <li>
                Abra <strong>Configurações → Conexões de rede</strong>
                e adicione <code>{@conn.host}</code>
                aos domínios permitidos.
              </li>
              <li>Abra uma conversa nova — a permissão não vale para conversas já iniciadas.</li>
              <li>
                Envie o link desta documentação e um token; o Claude passa a chamar a API REST
                diretamente.
              </li>
            </ol>
          </div>
          <div class="rounded-2xl border border-base-300 bg-base-100 p-5">
            <h4 class="font-bold">No Claude Code (terminal, desktop ou claude.ai/code)</h4>
            <p class="mt-1 text-sm leading-6 opacity-75">
              Conecte o servidor MCP com o token no header:
            </p>
            <pre class="mt-3 overflow-x-auto rounded-xl bg-neutral p-4 text-sm leading-6 text-neutral-content"><code phx-no-curly-interpolation>claude mcp add --transport http quizzes <%= url(~p"/api/mcp") %> \
  --header "Authorization: Bearer quiz_SEU_TOKEN"</code></pre>
          </div>
          <p class="rounded-2xl border border-info/30 bg-info/10 p-4 text-sm leading-6">
            Os conectores personalizados de Configurações → Conectores autenticam por OAuth e
            não aceitam um header Bearer próprio; para esta API, use as duas opções acima.
          </p>
        </div>

        <div
          id="ai-panel-chatgpt"
          class="hidden space-y-4 group-has-[#ai-tab-chatgpt:checked]/ai:block"
        >
          <div class="rounded-2xl border border-base-300 bg-base-100 p-5">
            <h4 class="font-bold">Sem suporte a MCP na interface web</h4>
            <p class="mt-1 text-sm leading-6 opacity-75">
              O chat do ChatGPT não permite liberar domínios para acesso direto nem conectar
              servidores MCP autenticados por Bearer token. A navegação passa por um proxy
              próprio, então chamadas a esta API tendem a falhar sem retornar um status HTTP.
              O caminho que funciona é um GPT personalizado com Actions: as chamadas partem
              dos servidores da OpenAI, fora do proxy de navegação.
            </p>
          </div>
          <div class="rounded-2xl border border-base-300 bg-base-100 p-5">
            <h4 class="font-bold">GPT personalizado com Actions — schema pronto para importar</h4>
            <p class="mt-1 text-sm leading-6 opacity-75">
              Esta aplicação publica o schema OpenAPI da API v1, então não é preciso
              escrever nada à mão:
            </p>
            <div class="mt-3 rounded-xl bg-neutral p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-neutral-content/60">
                URL do schema
              </p>
              <code
                id="openapi-schema-url"
                class="mt-1 block break-all text-sm text-neutral-content"
              >
                {url(~p"/api/openapi.json")}
              </code>
            </div>
            <ol class="mt-4 list-decimal space-y-2 pl-5 text-sm leading-6">
              <li>
                No ChatGPT (recurso de planos pagos), abra <strong>GPTs → Criar</strong>
                e vá à aba <strong>Configurar → Ações → Criar nova ação</strong>.
              </li>
              <li>
                Escolha <strong>Importar de URL</strong> e cole o endereço do schema acima.
              </li>
              <li>
                Em <strong>Autenticação</strong>, selecione <strong>Chave de API</strong>
                com tipo <strong>Bearer</strong>
                e cole um token <code>quiz_...</code>
                criado em Configurações → Tokens.
              </li>
              <li>
                Em <strong>Compartilhar</strong>, mantenha o acesso como <strong>Somente eu</strong>. Salve e converse com o GPT: ele passa a listar,
                criar, validar e publicar quizzes pela API REST. Ações de escrita pedem sua
                confirmação antes de executar.
              </li>
            </ol>
          </div>
          <div class="rounded-2xl border border-warning/40 bg-warning/10 p-5">
            <h4 class="font-bold">Por que o GPT deve ficar privado</h4>
            <p class="mt-1 text-sm leading-6">
              O token fica embutido na Action e é usado em todas as chamadas, seja quem for
              que estiver conversando com o GPT. Como todo token desta API carrega hoje os
              três escopos — leitura, escrita e publicação —, compartilhar o GPT por link ou
              na GPT Store entrega sua conta junto: qualquer pessoa poderia criar, alterar e
              publicar quizzes em seu nome, e os registros mostrariam você como autor, sem
              como distinguir quem realmente fez cada chamada. Compartilhar também exige
              publicar uma política de privacidade para o domínio da Action — mais um sinal
              de que esse fluxo foi pensado para expor um serviço ao público, não uma conta
              pessoal.
            </p>
            <p class="mt-2 text-sm leading-6">
              Se suspeitar que o token vazou, revogue-o em Configurações → Tokens: o acesso
              do GPT morre na hora. Enquanto não houver tokens de escopo reduzido, trate
              qualquer GPT com Action desta API como estritamente pessoal.
            </p>
          </div>
          <p class="rounded-2xl border border-info/30 bg-info/10 p-4 text-sm leading-6">
            Em aplicações próprias, a Responses API da OpenAI também aceita servidores MCP
            remotos com headers personalizados — aponte para <code>{url(~p"/api/mcp")}</code>.
          </p>
        </div>

        <div
          id="ai-panel-gemini"
          class="hidden space-y-4 group-has-[#ai-tab-gemini:checked]/ai:block"
        >
          <div class="rounded-2xl border border-base-300 bg-base-100 p-5">
            <h4 class="font-bold">Sem conectores no app web</h4>
            <p class="mt-1 text-sm leading-6 opacity-75">
              O app web do Gemini não oferece conectores MCP personalizados nem liberação de
              domínios para chamadas diretas.
            </p>
          </div>
          <div class="rounded-2xl border border-base-300 bg-base-100 p-5">
            <h4 class="font-bold">Gemini CLI</h4>
            <p class="mt-1 text-sm leading-6 opacity-75">
              O
              <a
                href="https://github.com/google-gemini/gemini-cli"
                target="_blank"
                rel="noopener noreferrer"
                class="font-semibold text-primary hover:underline"
              >
                Gemini CLI
              </a>
              — agente oficial do Google para o terminal, lançado em 2025 — conecta servidores
              MCP. Adicione ao <code>~/.gemini/settings.json</code>:
            </p>
            <pre class="mt-3 overflow-x-auto rounded-xl bg-neutral p-4 text-sm leading-6 text-neutral-content"><code phx-no-curly-interpolation>{
  "mcpServers": {
    "quizzes": {
      "httpUrl": "<%= url(~p"/api/mcp") %>",
      "headers": {
        "Authorization": "Bearer quiz_SEU_TOKEN"
      }
    }
  }
}</code></pre>
            <p class="mt-3 text-sm leading-6 opacity-75">
              Depois abra o <code>gemini</code>
              e rode <code>/mcp</code>
              para confirmar que as ferramentas foram carregadas.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="contratos" class="scroll-mt-6 space-y-6">
      <div>
        <p class="text-sm font-semibold text-primary">02 · Contratos</p>
        <h2 class="mt-1 text-2xl font-bold">Formato das requisições e respostas</h2>
        <p class="mt-2 max-w-3xl leading-7 opacity-70">
          Todos os corpos usam JSON em UTF-8. IDs são UUIDs; datas usam ISO 8601; valores
          decimais como <code>total_points</code> e <code>weight</code> retornam como strings.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-base-300 p-5">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-primary">Sucesso</p>
          <p phx-no-curly-interpolation class="mt-3 text-sm leading-6 opacity-75">
            Respostas com conteúdo usam <code>{"data": ...}</code>. Exclusões bem-sucedidas usam
            <code>204 No Content</code>
            sem corpo.
          </p>
        </div>
        <div class="rounded-2xl border border-base-300 p-5">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-primary">Atualizações</p>
          <p class="mt-3 text-sm leading-6 opacity-75">
            Corpos de <code>PATCH</code> são parciais. Campos desconhecidos são ignorados.
            Envie apenas os campos que deseja alterar.
          </p>
        </div>
        <div class="rounded-2xl border border-base-300 p-5">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-primary">Propriedade</p>
          <p class="mt-3 text-sm leading-6 opacity-75">
            A API mostra somente recursos da conta autenticada. Um recurso inexistente ou de
            outra conta retorna o mesmo <code>404</code>.
          </p>
        </div>
      </div>

      <div class="space-y-4">
        <h3 class="text-xl font-bold">Modelos retornados</h3>
        <.api_fields title="Quiz">
          <:field name="id" type="UUID" presence="Sempre">
            Identificador do agrupador do quiz.
          </:field>
          <:field name="public_slug" type="string" presence="Sempre">
            Slug do link público em <code>/q/:public_slug</code>.
          </:field>
          <:field name="active" type="boolean" presence="Sempre">
            Se <code>false</code>, o link existe, mas não aceita novas respostas.
          </:field>
          <:field name="inserted_at" type="datetime" presence="Sempre">Data de criação.</:field>
          <:field name="updated_at" type="datetime" presence="Sempre">Última alteração.</:field>
          <:field name="versions" type="VersionSummary[]" presence="Sempre">
            Versões da mais recente para a mais antiga. Cada item tem <code>id</code>, <code>version_number</code>, <code>name</code>, <code>status</code>,
            <code>published_at</code>
            e <code>updated_at</code>.
          </:field>
        </.api_fields>

        <.api_fields title="Version · versão completa">
          <:field name="id" type="UUID" presence="Sempre">Identificador da versão.</:field>
          <:field name="quiz_id" type="UUID" presence="Sempre">Identificador do quiz pai.</:field>
          <:field name="version_number" type="integer" presence="Sempre">
            Começa em 1 e cresce a cada novo rascunho.
          </:field>
          <:field name="name" type="string" presence="Sempre">Título do quiz.</:field>
          <:field name="description" type="string" presence="Sempre">
            Descrição; pode ser vazia.
          </:field>
          <:field name="total_points" type="decimal string" presence="Sempre">
            Exemplo: <code>"100"</code> ou <code>"7.5"</code>.
          </:field>
          <:field name="unequal_weights" type="boolean" presence="Sempre">
            Permite pesos diferentes entre questões.
          </:field>
          <:field name="question_order_mode" type="enum" presence="Sempre">
            <code>fixed</code>, <code>random</code> ou <code>ai</code>.
          </:field>
          <:field name="status" type="enum" presence="Sempre">
            <code>draft</code> ou <code>published</code>.
          </:field>
          <:field name="published_at" type="datetime | null" presence="Sempre">
            Nulo enquanto for rascunho.
          </:field>
          <:field name="changelog" type="string[]" presence="Sempre">
            Resumo de alterações gerado na publicação.
          </:field>
          <:field name="inserted_at" type="datetime" presence="Sempre">Data de criação.</:field>
          <:field name="updated_at" type="datetime" presence="Sempre">Última alteração.</:field>
          <:field name="questions" type="Question[]" presence="Sempre">
            Questões ordenadas por <code>position</code>.
          </:field>
        </.api_fields>

        <.api_fields title="Question">
          <:field name="id" type="UUID" presence="Sempre">
            Identificador desta questão na versão.
          </:field>
          <:field name="identity_key" type="UUID" presence="Sempre">
            Identidade estável da questão entre versões.
          </:field>
          <:field name="position" type="integer" presence="Sempre">
            Posição iniciada em zero.
          </:field>
          <:field name="statement" type="string" presence="Sempre">Enunciado.</:field>
          <:field name="type" type="enum" presence="Sempre">
            <code>true_false</code>, <code>single</code>, <code>multiple</code>
            ou <code>text</code>.
          </:field>
          <:field name="allow_partial_credit" type="boolean" presence="Sempre">
            Usado em questões <code>multiple</code>.
          </:field>
          <:field name="true_false_answer" type="boolean | null" presence="Sempre">
            Resposta de questões <code>true_false</code>.
          </:field>
          <:field name="editor_note" type="string | null" presence="Sempre">
            Resposta de referência e explicação.
          </:field>
          <:field name="weight" type="decimal string | null" presence="Sempre">
            Peso quando <code>unequal_weights</code> estiver ativo.
          </:field>
          <:field name="annulled" type="boolean" presence="Sempre">
            Informa se a questão foi anulada.
          </:field>
          <:field name="annulled_reason" type="string | null" presence="Sempre">
            Motivo da anulação.
          </:field>
          <:field name="options" type="Option[]" presence="Sempre">
            Lista vazia para questões sem alternativas.
          </:field>
        </.api_fields>

        <.api_fields title="Option">
          <:field name="id" type="UUID" presence="Sempre">Identificador da alternativa.</:field>
          <:field name="identity_key" type="UUID" presence="Sempre">
            Identidade estável entre versões.
          </:field>
          <:field name="position" type="integer" presence="Sempre">
            Posição iniciada em zero.
          </:field>
          <:field name="text" type="string" presence="Sempre">
            Texto exibido ao participante.
          </:field>
          <:field name="correct" type="boolean" presence="Sempre">
            Se a alternativa compõe o gabarito.
          </:field>
        </.api_fields>

        <div class="overflow-hidden rounded-2xl border border-base-300 bg-neutral text-neutral-content">
          <div class="border-b border-white/10 px-5 py-3 text-xs opacity-70">
            Exemplo de resposta Version · campos sem valor retornam null
          </div>
          <pre class="overflow-x-auto p-5 text-sm leading-6"><code phx-no-curly-interpolation>{
  "data": {
    "id": "VERSION_UUID",
    "quiz_id": "QUIZ_UUID",
    "version_number": 1,
    "name": "Fundamentos de Elixir",
    "description": "Conceitos básicos",
    "total_points": "100",
    "unequal_weights": false,
    "question_order_mode": "fixed",
    "status": "draft",
    "published_at": null,
    "changelog": [],
    "inserted_at": "2026-07-04T21:00:00Z",
    "updated_at": "2026-07-04T21:00:00Z",
    "questions": [
      {
        "id": "QUESTION_UUID",
        "identity_key": "STABLE_QUESTION_UUID",
        "position": 0,
        "statement": "Elixir roda na BEAM?",
        "type": "true_false",
        "allow_partial_credit": false,
        "true_false_answer": true,
        "editor_note": "Sim, Elixir compila para bytecode da BEAM.",
        "weight": null,
        "annulled": false,
        "annulled_reason": null,
        "options": []
      }
    ]
  }
}</code></pre>
        </div>
      </div>
    </section>

    <section id="endpoints" class="scroll-mt-6 space-y-6">
      <div>
        <p class="text-sm font-semibold text-primary">03 · Referência</p>
        <h2 class="mt-1 text-2xl font-bold">Endpoints e parâmetros</h2>
        <p class="mt-2 max-w-3xl leading-7 opacity-70">
          Abra uma rota para ver corpo, regras e resposta. Todas exigem Bearer token, exceto a
          emissão inicial em <code>POST /auth/tokens</code>.
        </p>
      </div>

      <div class="space-y-3">
        <h3 class="text-lg font-bold">Quizzes</h3>

        <.api_endpoint
          id="endpoint-list-quizzes"
          method="GET"
          path="/api/v1/quizzes"
          scope="token válido"
          response="200 · Quiz[]"
        >
          <p class="text-sm leading-6 opacity-75">
            Lista os quizzes da conta, do mais recente para o mais antigo. Não recebe query
            params nem paginação atualmente. Cada quiz inclui resumos das suas versões.
          </p>
          <p phx-no-curly-interpolation class="text-sm">
            <strong>Resposta:</strong> <code>{"data": [Quiz, ...]}</code>
          </p>
        </.api_endpoint>

        <.api_endpoint
          id="endpoint-create-quiz"
          method="POST"
          path="/api/v1/quizzes"
          scope="quizzes:write"
          response="201 · Version"
        >
          <p class="text-sm leading-6 opacity-75">
            Cria um quiz e sua versão 1 em estado <code>draft</code>. O corpo pode ser vazio;
            nome e questões são exigidos apenas para publicar.
          </p>
          <.api_fields title="Body JSON">
            <:field name="name" type="string" presence="Opcional · padrão vazio">
              Título do quiz.
            </:field>
            <:field name="description" type="string" presence="Opcional · padrão vazio">
              Descrição do quiz.
            </:field>
            <:field
              name="total_points"
              type="number | decimal string"
              presence="Opcional · padrão 100"
            >
              Precisa ser maior que zero.
            </:field>
            <:field name="unequal_weights" type="boolean" presence="Opcional · padrão false">
              Ativa pesos por questão.
            </:field>
            <:field name="question_order_mode" type="enum" presence="Opcional · padrão fixed">
              <code>fixed</code>, <code>random</code> ou <code>ai</code>.
            </:field>
          </.api_fields>
          <p class="text-sm">
            <strong>Resposta:</strong>
            versão completa, incluindo <code>quiz_id</code>
            e <code>questions: []</code>.
          </p>
        </.api_endpoint>

        <.api_endpoint
          id="endpoint-import-quiz"
          method="POST"
          path="/api/v1/quizzes/import"
          scope="quizzes:write"
          response="201 · Version"
        >
          <p class="text-sm leading-6 opacity-75">
            Cria um rascunho completo em uma chamada. Este endpoint usa deliberadamente chaves em
            português e o mesmo formato do importador da interface.
          </p>
          <.api_fields title="Body raiz · formato de importação">
            <:field name="nome" type="string" presence="Obrigatório">
              Não pode estar vazio.
            </:field>
            <:field name="descricao" type="string" presence="Opcional · padrão vazio">
              Descrição do quiz.
            </:field>
            <:field name="nota_total" type="number > 0" presence="Opcional · padrão 100">
              Nota máxima.
            </:field>
            <:field name="pesos_desiguais" type="boolean" presence="Opcional · padrão false">
              Permite <code>peso</code> por questão.
            </:field>
            <:field name="modo_ordem" type="enum" presence="Opcional · padrão fixa">
              <code>fixa</code>, <code>aleatoria</code> ou <code>ia</code>.
            </:field>
            <:field name="questoes" type="QuestãoImportada[]" presence="Obrigatório">
              Lista com pelo menos uma questão.
            </:field>
          </.api_fields>
          <.api_fields title="Cada item de questoes">
            <:field name="enunciado" type="string" presence="Obrigatório">
              Não pode estar vazio.
            </:field>
            <:field name="tipo" type="enum" presence="Obrigatório">
              <code>verdadeiro_falso</code>, <code>unica</code>, <code>multipla</code>
              ou <code>discursiva</code>.
            </:field>
            <:field
              name="resposta_verdadeiro_falso"
              type="boolean"
              presence="Obrigatório em verdadeiro_falso"
            >
              Gabarito da afirmação.
            </:field>
            <:field
              name="alternativas"
              type="AlternativaImportada[]"
              presence="Obrigatório em unica/multipla"
            >
              Ao menos 2 itens com <code>texto</code> e <code>correta</code>.
            </:field>
            <:field name="nota_parcial" type="boolean" presence="Opcional em multipla">
              Concede crédito proporcional quando não houver marcação errada.
            </:field>
            <:field name="resposta_referencia" type="string" presence="Opcional">
              Explicação e referência para correção discursiva por IA.
            </:field>
            <:field name="peso" type="number >= 0" presence="Opcional">
              Usado quando <code>pesos_desiguais</code> for verdadeiro.
            </:field>
          </.api_fields>
          <.api_fields title="Cada item de alternativas">
            <:field name="texto" type="string" presence="Obrigatório">
              Texto da alternativa.
            </:field>
            <:field name="correta" type="boolean" presence="Opcional · padrão false">
              Marca a alternativa como parte do gabarito.
            </:field>
          </.api_fields>
          <p class="text-sm leading-6 opacity-75">
            Em <code>unica</code>, exatamente uma alternativa deve ter <code>correta: true</code>;
            em <code>multipla</code>, pelo menos uma. Chaves desconhecidas são ignoradas.
          </p>
          <.link
            href={~p"/formato-importacao.md"}
            class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline"
          >
            <.icon name="hero-arrow-down-tray" class="size-4" />
            Baixar contrato completo e exemplo JSON
          </.link>
        </.api_endpoint>

        <.api_endpoint
          id="endpoint-show-quiz"
          method="GET"
          path="/api/v1/quizzes/:id"
          scope="token válido"
          response="200 · Quiz"
        >
          <.api_fields title="Path params">
            <:field name="id" type="UUID" presence="Obrigatório">
              ID do quiz, não da versão.
            </:field>
          </.api_fields>
          <p class="text-sm">
            <strong>Resposta:</strong>
            quiz com a lista de resumos das versões. O conteúdo das questões não vem nesta rota.
          </p>
        </.api_endpoint>

        <.api_endpoint
          id="endpoint-update-quiz"
          method="PATCH"
          path="/api/v1/quizzes/:id"
          scope="quizzes:write"
          response="200 · Quiz"
        >
          <.api_fields title="Body JSON">
            <:field name="active" type="boolean" presence="Obrigatório">
              <code>false</code> impede novas respostas; <code>true</code> reabre o quiz.
            </:field>
          </.api_fields>
          <p class="text-sm">
            Ausência ou tipo incorreto em <code>active</code>
            retorna <code>422 validation_error</code>.
          </p>
        </.api_endpoint>

        <.api_endpoint
          id="endpoint-create-draft"
          method="POST"
          path="/api/v1/quizzes/:id/drafts"
          scope="quizzes:write"
          response="201 · Version"
        >
          <p class="text-sm leading-6 opacity-75">
            Retorna o rascunho existente. Se não houver um, copia a versão publicada mais
            recente para a próxima <code>version_number</code>, preservando identidades de questões
            e alternativas. Não recebe body.
          </p>
          <.api_fields title="Path params">
            <:field name="id" type="UUID" presence="Obrigatório">ID do quiz.</:field>
          </.api_fields>
        </.api_endpoint>
      </div>

      <div class="space-y-3">
        <h3 class="text-lg font-bold">Versões e publicação</h3>

        <.api_endpoint
          id="endpoint-show-version"
          method="GET"
          path="/api/v1/quiz-versions/:id"
          scope="token válido"
          response="200 · Version"
        >
          <.api_fields title="Path params">
            <:field name="id" type="UUID" presence="Obrigatório">
              ID da versão obtido em <code>Quiz.versions</code>.
            </:field>
          </.api_fields>
          <p class="text-sm">Retorna a versão completa, com todas as questões e alternativas.</p>
        </.api_endpoint>

        <.api_endpoint
          id="endpoint-update-version"
          method="PATCH"
          path="/api/v1/quiz-versions/:id"
          scope="quizzes:write"
          response="200 · Version"
        >
          <p class="text-sm leading-6 opacity-75">
            Edita somente rascunhos. Todos os campos são opcionais e a resposta traz a versão completa recarregada.
          </p>
          <.api_fields title="Body JSON parcial">
            <:field name="name" type="string" presence="Opcional">Título.</:field>
            <:field name="description" type="string" presence="Opcional">Descrição.</:field>
            <:field name="total_points" type="number | decimal string" presence="Opcional">
              Precisa ser maior que zero.
            </:field>
            <:field name="unequal_weights" type="boolean" presence="Opcional">
              Ativa pesos por questão.
            </:field>
            <:field name="question_order_mode" type="enum" presence="Opcional">
              <code>fixed</code>, <code>random</code> ou <code>ai</code>.
            </:field>
          </.api_fields>
        </.api_endpoint>

        <.api_endpoint
          id="endpoint-validate-version"
          method="POST"
          path="/api/v1/quiz-versions/:id/validate"
          scope="token válido"
          response="200 · Validation"
        >
          <p class="text-sm leading-6 opacity-75">
            Executa as mesmas regras da publicação sem alterar nada. Uma validação
            negativa ainda retorna HTTP 200; consulte <code>data.valid</code>. Não recebe body.
          </p>
          <pre class="overflow-x-auto rounded-xl bg-neutral p-4 text-sm leading-6 text-neutral-content"><code phx-no-curly-interpolation>{
  "data": {
    "valid": false,
    "errors": ["O quiz precisa de um nome", "O quiz precisa de pelo menos uma questão"]
  }
}</code></pre>
        </.api_endpoint>

        <.api_endpoint
          id="endpoint-publish-version"
          method="POST"
          path="/api/v1/quiz-versions/:id/publish"
          scope="quizzes:publish"
          response="200 · Version"
        >
          <p class="text-sm leading-6 opacity-75">
            Valida, publica e congela o rascunho. Também gera tags internas de IA e o changelog.
            Não recebe body. Se houver problemas de conteúdo, retorna <code>422</code> com todos
            os erros em <code>error.details</code>.
          </p>
          <div class="rounded-xl border border-base-300 bg-base-100 p-4 text-sm leading-6">
            <strong>Regras principais:</strong>
            nome preenchido, pelo menos uma questão, nota total
            positiva, enunciados preenchidos e gabarito coerente com cada tipo. Se pesos desiguais
            estiverem ativos, a soma dos pesos definidos não pode exceder a nota total.
          </div>
        </.api_endpoint>
      </div>

      <div class="space-y-3">
        <h3 class="text-lg font-bold">Questões e alternativas</h3>

        <.api_endpoint
          id="endpoint-create-question"
          method="POST"
          path="/api/v1/quiz-versions/:id/questions"
          scope="quizzes:write"
          response="201 · Question"
        >
          <p class="text-sm leading-6 opacity-75">
            Adiciona uma questão ao fim do rascunho. A posição é atribuída automaticamente.
            O endpoint permite salvar incompleto; use a validação antes de publicar.
          </p>
          <.api_fields title="Body JSON">
            <:field name="statement" type="string" presence="Opcional · padrão vazio">
              Enunciado.
            </:field>
            <:field name="type" type="enum" presence="Opcional · padrão single">
              <code>true_false</code>, <code>single</code>, <code>multiple</code>
              ou <code>text</code>.
            </:field>
            <:field
              name="allow_partial_credit"
              type="boolean"
              presence="Opcional · padrão false"
            >
              Use apenas com <code>multiple</code>.
            </:field>
            <:field
              name="true_false_answer"
              type="boolean | null"
              presence="Exigido para publicar true_false"
            >
              Gabarito verdadeiro/falso.
            </:field>
            <:field name="editor_note" type="string | null" presence="Opcional">
              Explicação ou resposta de referência.
            </:field>
            <:field name="weight" type="number | decimal string | null" presence="Opcional">
              Peso da questão.
            </:field>
            <:field name="options" type="OptionInput[]" presence="Opcional · padrão []">
              Alternativas com <code>text</code>, <code>correct</code> e <code>position</code>.
            </:field>
          </.api_fields>
          <pre class="overflow-x-auto rounded-xl bg-neutral p-4 text-sm leading-6 text-neutral-content"><code phx-no-curly-interpolation>{
  "statement": "Quais valores são booleanos?",
  "type": "multiple",
  "allow_partial_credit": true,
  "editor_note": "true e false são os booleanos de Elixir.",
  "options": [
    {"text": "true", "correct": true, "position": 0},
    {"text": "false", "correct": true, "position": 1},
    {"text": "nil", "correct": false, "position": 2}
  ]
}</code></pre>
        </.api_endpoint>

        <.api_endpoint
          id="endpoint-update-question"
          method="PATCH"
          path="/api/v1/questions/:id"
          scope="quizzes:write"
          response="200 · Question"
        >
          <p class="text-sm leading-6 opacity-75">
            Atualiza uma questão de rascunho. Aceita os mesmos campos da criação, além de <code>position</code>. Se
            <code>options</code>
            for omitido, as alternativas permanecem;
            se for enviado, ele substitui a coleção inteira.
          </p>
          <.api_fields title="Regras de options no PATCH">
            <:field name="options[].id" type="UUID" presence="Para manter uma alternativa">
              IDs existentes preservam identidade e atualizam o item.
            </:field>
            <:field name="options[].text" type="string" presence="Opcional">
              Texto da alternativa.
            </:field>
            <:field name="options[].correct" type="boolean" presence="Opcional · padrão false">
              Participa do gabarito.
            </:field>
            <:field name="options[].position" type="integer" presence="Opcional · padrão 0">
              Ordem da alternativa.
            </:field>
          </.api_fields>
          <p class="rounded-xl border border-warning/30 bg-warning/10 p-4 text-sm leading-6">
            Atenção: alternativas existentes omitidas da lista enviada são excluídas; itens sem
            <code>id</code>
            são criados como novas alternativas.
          </p>
        </.api_endpoint>

        <.api_endpoint
          id="endpoint-delete-question"
          method="DELETE"
          path="/api/v1/questions/:id"
          scope="quizzes:write"
          response="204 · sem corpo"
        >
          <p class="text-sm leading-6 opacity-75">
            Remove a questão de um rascunho e renumera as posições restantes. Questões de
            versões publicadas não podem ser removidas.
          </p>
          <.api_fields title="Path params">
            <:field name="id" type="UUID" presence="Obrigatório">
              ID da questão, não o <code>identity_key</code>.
            </:field>
          </.api_fields>
        </.api_endpoint>
      </div>

      <div class="space-y-3">
        <h3 class="text-lg font-bold">Token atual</h3>
        <.api_endpoint
          id="endpoint-revoke-token"
          method="DELETE"
          path="/api/v1/auth/token"
          scope="token válido"
          response="204 · sem corpo"
        >
          <p class="text-sm leading-6 opacity-75">
            Revoga imediatamente o Bearer token usado nesta requisição. As demais credenciais da
            conta continuam ativas. Não recebe path params nem body.
          </p>
        </.api_endpoint>
      </div>
    </section>

    <section id="fluxo-completo" class="scroll-mt-6 space-y-5">
      <div>
        <p class="text-sm font-semibold text-primary">04 · Fluxo recomendado</p>
        <h2 class="mt-1 text-2xl font-bold">Do rascunho à publicação</h2>
      </div>
      <ol class="grid gap-4 md:grid-cols-2">
        <li class="rounded-2xl border border-base-300 p-5">
          <span class="text-xs font-bold text-primary">1 · CRIAR</span>
          <p class="mt-2 font-semibold">
            <code>POST /quizzes</code> ou <code>POST /quizzes/import</code>
          </p>
          <p class="mt-1 text-sm leading-6 opacity-70">
            Guarde <code>data.id</code> como VERSION_ID e <code>data.quiz_id</code> como QUIZ_ID.
          </p>
        </li>
        <li class="rounded-2xl border border-base-300 p-5">
          <span class="text-xs font-bold text-primary">2 · EDITAR</span>
          <p class="mt-2 font-semibold"><code>PATCH /quiz-versions/VERSION_ID</code></p>
          <p class="mt-1 text-sm leading-6 opacity-70">
            Ajuste metadados e adicione questões enquanto o status for <code>draft</code>.
          </p>
        </li>
        <li class="rounded-2xl border border-base-300 p-5">
          <span class="text-xs font-bold text-primary">3 · VALIDAR</span>
          <p class="mt-2 font-semibold"><code>POST /quiz-versions/VERSION_ID/validate</code></p>
          <p class="mt-1 text-sm leading-6 opacity-70">
            Prossiga apenas quando <code>data.valid</code> for <code>true</code>.
          </p>
        </li>
        <li class="rounded-2xl border border-base-300 p-5">
          <span class="text-xs font-bold text-primary">4 · PUBLICAR</span>
          <p class="mt-2 font-semibold"><code>POST /quiz-versions/VERSION_ID/publish</code></p>
          <p class="mt-1 text-sm leading-6 opacity-70">
            A versão se torna imutável. Use <code>POST /quizzes/QUIZ_ID/drafts</code>
            para a próxima edição.
          </p>
        </li>
      </ol>
    </section>

    <section id="erros" class="scroll-mt-6 space-y-5">
      <div>
        <p class="text-sm font-semibold text-primary">05 · Erros</p>
        <h2 class="mt-1 text-2xl font-bold">Códigos e formatos de falha</h2>
      </div>
      <.api_fields title="Respostas de erro">
        <:field
          name="401 unauthorized"
          type="error object"
          presence="Token ausente, inválido, revogado ou expirado"
        >
          Inclui <code>WWW-Authenticate: Bearer realm="quiz-api"</code>.
        </:field>
        <:field
          name="401 invalid_credentials"
          type="error object"
          presence="Falha ao emitir token"
        >
          E-mail ou senha inválidos.
        </:field>
        <:field name="403 insufficient_scope" type="error object" presence="Escopo ausente">
          Inclui <code>required_scope</code>.
        </:field>
        <:field name="404 not_found" type="error object" presence="Ausente ou de outra conta">
          Não revela a existência de recursos alheios.
        </:field>
        <:field
          name="409 version_not_editable"
          type="error object"
          presence="Estado incompatível"
        >
          Operação de escrita em versão publicada.
        </:field>
        <:field
          name="409 published_version_required"
          type="error object"
          presence="Sem base para novo rascunho"
        >
          Não existe versão publicada para copiar.
        </:field>
        <:field
          name="422 validation_error"
          type="error + details[]"
          presence="Parâmetros ou conteúdo inválidos"
        >
          As mensagens legíveis ficam em <code>error.details</code>.
        </:field>
        <:field name="422 operation_failed" type="error object" presence="Falha não classificada">
          A operação não pôde ser concluída.
        </:field>
      </.api_fields>
      <pre class="overflow-x-auto rounded-2xl bg-neutral p-5 text-sm leading-6 text-neutral-content"><code phx-no-curly-interpolation>{
  "error": {
    "code": "validation_error",
    "details": [
      "Questão 1: precisa de pelo menos 2 alternativas",
      "Questão 1: marque exatamente 1 alternativa correta"
    ]
  }
}</code></pre>
    </section>
  </div>
</Layouts.app>
